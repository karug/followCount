# YouTube Data API v3 (required for youtube channels)
YOUTUBE_API_KEY=

# GitHub personal access token (optional, raises rate limits)
GITHUB_TOKEN=

# Twitch application credentials (required for twitch channels)
# https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# X API v2 bearer token (required for x channels)
# https://developer.x.com
X_BEARER_TOKEN=

# Facebook Graph API access token (optional: without it the public
# embed widget is scraped, which rounds big counts, e.g. "154M")
# https://developers.facebook.com
FACEBOOK_ACCESS_TOKEN=

# Server port (default 3000)
# PORT=3000
